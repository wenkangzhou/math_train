    "lint": "tsc --noEmit",
    "gen:icons": "node scripts/gen-icons.mjs",
    "shots": "node scripts/shot.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.408.0",
    "react": "^18.3.1",
