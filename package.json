{
  "name": "math-train",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "数数小火车 / Math Train — 20 以内加减法练习",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/build-sw.mjs",
